#!/bin/bash
#PBS -N gentracks_rrfs
#PBS -j oe
#PBS -S /bin/bash
#PBS -q dev
#PBS -l walltime=01:00:00
#PBS -A ENSTRACK-DEV
#PBS -l select=1:ncpus=1:mem=40GB 
#PBS -l debug=true

model=gentracks
#%include <head.h>
#%include <envir-p1.h>

##############################
# Load modules
##############################
module reset
export target=wcoss2
source /lfs/h2/emc/ens/noscrub/hananeh.jafary/rrfs/gentracks.v3.6.1/versions/run.ver
#module load ${target}.lua
module list

module load intel/$intel_ver
module load PrgEnv-intel/$PrgEnv_intel_ver
module load craype/$craype_ver
module load cray-mpich/$cray_mpich_ver
module load cray-pals/$cray_pals_ver
module load libjpeg/$libjpeg_ver
module load grib_util/$grib_util_ver
module load hdf5-D/$hdf5_ver
module load netcdf-D/$netcdf_ver
module load libaec/$libaec_ver
module load g2c/$g2c_ver
module load libjpeg-turbo/$libjpeg_turbo_ver
module load wgrib2/$wgrib2_rrfs_ver

module list

# EXPORT list here
set -x
export cmodel=rrfs
export NETIN=dcom
export RUN=rrfs
#export cyc=%CYC%

export cyc=00
export model=ens_tracker
export envir=prod
export KEEPDATA=YES

export DATAROOT=/lfs/h2/emc/ptmp/hananeh.jafary
export HOMEgentracks=/lfs/h2/emc/ens/noscrub/hananeh.jafary/rrfs/gentracks.v3.6.1
${HOMEgentracks}/dev/jobs/JTRACKER

#if [ $? -ne 0 ]; then
#  ecflow_client --msg="***JOB ${ECF_NAME} ERROR RUNNING J-SCRIPT ***"
#  ecflow_client --abort
#  exit
#fi

